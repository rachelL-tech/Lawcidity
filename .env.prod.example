# RDS PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT:5432/citations

# OpenSearch (container-internal)
OPENSEARCH_INDEX=decisions_v2
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=YOUR_OPENSEARCH_STRONG_PASSWORD
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_URL=https://localhost:9200

EMBED_BACKEND=cf
CF_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CF_AI_TOKEN=YOUR_CLOUDFLARE_API_TOKEN

# AI services
GROQ_API_KEY=YOUR_GROQ_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY